{
  "expo": {
    "name": "Casas Kitnet",
    "slug": "casaskitnetmanager",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "casaskitnet",
    "android": {
      "package": "com.casaskitnet.manager",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acesso às fotos para adicionar imagens às kitnets."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "c02ba647-63a4-4aec-857e-7e72411f5172"
      }
    }
  }
}
